<!DOCTYPE html>
<html>

<head>
    <title>Admin Panel</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>

    <div class="admin-container">

        <h1>Admin Dashboard</h1>
        <h3>Registered Users</h3>

        <table class="admin-table">

            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
            </tr>

            <% users.forEach(function(user){ %>

            <tr>
                <td><%= user.id %></td>
                <td><%= user.name %></td>
                <td><%= user.email %></td>
            </tr>

            <% }) %>

        </table>

    </div>

</body>

</html>